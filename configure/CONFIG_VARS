DOCKER_BUILDER := $(TOP)/docker_builder.bash
RELEASE_TOOL := $(TOP)/release.bash
TRIGGER_TOOL := $(TOP)/trigger.bash
SCRIPT_FILES := $(DOCKER_BUILDER) $(RELEASE_TOOL) $(TRIGGER_TOOL)
WORKFLOW_FILES := $(wildcard $(TOP)/.github/workflows/*.yml)
IMAGE_DRY_RUN_TARGETS := $(addprefix dry-run.,$(IMAGE_DIRS))
IMAGE_BUILD_TARGETS := $(addprefix build.,$(IMAGE_DIRS))

VARS_EXCLUDES += DOCKER_BUILDER RELEASE_TOOL TRIGGER_TOOL SCRIPT_FILES
VARS_EXCLUDES += WORKFLOW_FILES IMAGE_DRY_RUN_TARGETS IMAGE_BUILD_TARGETS
